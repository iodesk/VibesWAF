# Application Mode Configuration
# Test/Debug Mode: APP_DEBUG=true, LOG_LEVEL=info
# Production Mode: APP_DEBUG=false, LOG_LEVEL=error
APP_DEBUG=false
LOG_LEVEL=error
HTTP_PORT=127.0.0.1:3044
ACME_PORT=:8080

CLICKHOUSE_HOST=127.0.0.1:3001
CLICKHOUSE_DB=vibeswaf
CLICKHOUSE_USER=vibeswaf
CLICKHOUSE_PASSWORD=vibeswaf
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT="1"

DB_HOST=127.0.0.1
PSQL_PORT=3002
PSQL_NAME=vibeswaf
PSQL_USER=vibeswaf
PSQL_PASS=vibeswaf
PSQL_SSL=disable
#DB_SSL_PATH=data/ssl/pgsql.pem
PSQL_MAX_OPEN_CONNS=50
PSQL_MAX_IDLE_CONNS=25
PSQL_CONN_MAX_LIFETIME_MIN=30
PSQL_CONN_MAX_IDLE_MIN=5

REDIS_HOST=/var/run/redis/redis.sock
REDIS_PASS=
ENABLE_REDIS=true

# SSL & ACME Configuration
# acme.sh is installed in the wafer user's home. Go does not expand '~',
# so use an absolute path.
ACME_SH_PATH=/opt/vibeswaf/.acme.sh/acme.sh
ACME_EMAIL=admin@vibeswaf.local
CERT_DIR=/opt/certs
CERT_CACHE_DIR=data/cert-cache
SSL_PROVISION_TICKER_SEC=60
SSL_RENEW_THRESHOLD_SEC=1209600
SSL_AUTO_VERIFY_TICKER_SEC=30

# WAF Configuration
WAF_SECRET=vibeswaf-vibeswaf-vibeswaf-vibeswaf-vibeswaf
CONFIG_CACHE_TTL=300
LOG_BATCH_SIZE=1000
LOG_BATCH_TIMEOUT=5

# Authentication Configuration
SESSION_SECRET=
SESSION_DURATION_HOURS=72
BCRYPT_COST=10

# API Rate Limit Configuration
API_RATE_LIMIT=60
API_RATE_LIMIT_AUTH=120
API_RATE_WINDOW_SEC=60
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SEC=60

# Stream Configuration
STREAM_CONF_DIR=/etc/openresty/stream.d
STREAM_PORT_MIN=10000
STREAM_PORT_MAX=19999

# Spamhaus DROP Lists
SPAMHAUS_DROP_V4_URL=https://www.spamhaus.org/drop/drop_v4.json
SPAMHAUS_DROP_V6_URL=https://www.spamhaus.org/drop/drop_v6.json
SPAMHAUS_ASN_DROP_URL=https://www.spamhaus.org/drop/asndrop.json

# Dashboard SPA
DASHBOARD_HOST=waf.demo.com

# DEMO=true enables demo mode (global config locked, per-app editable only)
# DEMO_DOMAIN_IMO is the immortal domain that is never deleted on reset
# DEMO_AUTO_DEL=0 disables auto reset; set to hours (e.g. 24) to enable
DEMO=false
DEMO_DOMAIN_IMO=def.demo.com
DEMO_AUTO_DEL=0
